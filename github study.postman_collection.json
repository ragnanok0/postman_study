          "name": "유효성 테스트_너무 긴 텍스트(413)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. 서버가 터지지 않고 응답을 주는지 확인\r",
                  "pm.test(\"서버가 응답을 반환함\", function () {\r",
                  "    pm.response.to.be.withBody;\r",
                  "});\r",
                  "\r",
                  "// 2. 응답 코드가 201(성공)이거나 413(너무 큼)인지 확인\r",
                  "pm.test(\"정상 생성되었거나 거절됨 (500 에러 아님)\", function () {\r",
                  "    pm.expect(pm.response.code).to.be.oneOf([201, 413]);\r",
                  "});\r",
                  "\r",
                  "// 3. 만약 생성되었다면, 데이터가 잘리지 않았는지 확인 (선택 사항)\r",
                  "pm.test(\"데이터가 포함되어 있음\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.title).to.exist;\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {}
              }
            }
