              "script": {
                "exec": [
                  "// 1. 서버가 잘못된 요청임을 인지하는지 확인 \r",
                  "// (실무 API라면 400을 기대하지만, 연습용 API는 201이 나올 수 있습니다)\r",
                  "pm.test(\"요청 처리 확인\", function () {\r",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201, 400]);\r",
                  "});\r",
                  "\r",
                  "// 2. 응답 본문에서 userId의 상태 확인\r",
                  "pm.test(\"userId 필드 검증\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    // 보내준 \"QA_USER_999\"가 그대로 들어왔는지 확인\r",
                  "    pm.expect(jsonData.userId).to.eql(\"QA_USER_999\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {}
              }
            }
