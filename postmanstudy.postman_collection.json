{
	"info": {
		"name": "API_Flow_Practice",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. 게시글 생성 (POST)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('201 생성 성공 확인', function () {",
							"    pm.response.to.have.status(201);",
							"});",
							"",
							"if (pm.response.code === 201) {",
							"    var jsonData = pm.response.json();",
							"    // 생성된 ID를 글로벌 변수에 저장",
							"    pm.globals.set('new_post_id', jsonData.id);",
							"    console.log('생성된 게시글 ID:', jsonData.id);",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Content-Type", "value": "application/json" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"title\": \"QA_Test\",\n    \"body\": \"Flow_Test\",\n    \"userId\": 1\n}"
				},
				"url": {
					"raw": "https://jsonplaceholder.typicode.com/posts"
				}
			}
		},
		{
			"name": "2. 생성된 게시글 조회 (GET)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('200 조회 성공 확인', function () {",
							"    pm.response.to.have.status(200);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"url": {
					"raw": "https://jsonplaceholder.typicode.com/posts/{{new_post_id}}"
				}
			}
		}
	]
}
