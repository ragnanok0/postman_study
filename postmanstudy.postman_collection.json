{
	"info": {
		"name": "ReqRes_Practice",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. 유저 생성 (POST)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('201 생성 성공', () => { pm.response.to.have.status(201); });",
							"var res = pm.response.json();",
							"console.log('생성된 이름:', res.name);"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [{ "key": "Content-Type", "value": "application/json" }],
				"body": {
					"mode": "raw",
					"raw": "{\"name\": \"QA_Tester\", \"job\": \"QA Engineer\"}"
				},
				"url": "https://reqres.in/api/users"
			}
		},
		{
			"name": "2. 유저 목록 조회 (GET)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('200 조회 성공', () => { pm.response.to.have.status(200); });"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"url": "https://reqres.in/api/users?page=2"
			}
		}
	]
}
