{
  "info": {
    "_postman_id": "71fe087d-0ee9-4031-b880-1ad6eb2da964",
    "name": "postmanstudy",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "10913074"
  },
  "item": [
    {
      "name": "gorest 연습",
      "item": [
        {
          "name": "계정정보 등록",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.globals.set(\"generated_user_id\", jsonData.id);",
                  "    console.log(\"확정된 사용자 ID 저장 완료:\", jsonData.id);",
                  "} else {",
                  "    console.log(\"생성 실패! 응답 코드:\", pm.response.code);",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const now = new Date();",
                  "const dateStr = now.getFullYear() + String(now.getMonth() + 1).padStart(2, '0') + String(now.getDate()).padStart(2, '0');",
                  "const randomNum = Math.floor(1000 + Math.random() * 9000);",
                  "const uniqueName = `osm_qa_${dateStr}_${randomNum}`;",
                  "const uniqueEmail = `${uniqueName}@example.com`;",
                  "pm.variables.set(\"dynamicName\", uniqueName);",
                  "pm.variables.set(\"dynamicEmail\", uniqueEmail);",
                  "console.log(\"준비된 이메일:\", uniqueEmail);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"{{dynamicName}}\",\n    \"gender\": \"male\",\n    \"email\": \"{{dynamicEmail}}\",\n    \"status\": \"active\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "https://gorest.co.in/public/v2/users",
              "protocol": "https",
              "host": ["gorest", "co", "in"],
              "path": ["public", "v2", "users"]
            }
          },
          "response": []
        },
        {
          "name": "등록한 계정정보 조회",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://gorest.co.in/public/v2/users/{{generated_user_id}}",
              "protocol": "https",
              "host": ["gorest", "co", "in"],
              "path": ["public", "v2", "users", "{{generated_user_id}}"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
