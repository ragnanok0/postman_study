{
	"info": {
		"name": "Postman_Echo_Test",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. 데이터 전송 테스트 (POST)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('200 OK 확인', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"var res = pm.response.json();",
							"console.log('서버가 받은 데이터:', res.data.name);"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [{ "key": "Content-Type", "value": "application/json" }],
				"body": {
					"mode": "raw",
					"raw": "{\"name\": \"QA_Engineer_Test\", \"status\": \"success\"}"
				},
				"url": "https://postman-echo.com/post"
			}
		},
		{
			"name": "2. 데이터 조회 테스트 (GET)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('200 OK 확인', function () {",
							"    pm.response.to.have.status(200);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"url": "https://postman-echo.com/get?test=true"
			}
		}
	]
}
