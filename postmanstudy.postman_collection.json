  "item": [
    {
      "name": "gorest 연습",
      "item": [
        {
          "name": "계정정보 등록",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. 현재 날짜와 시간 가져오기 (YYYYMMDD 형식)\r",
                  "const now = new Date();\r",
                  "const year = now.getFullYear();\r",
                  "const month = String(now.getMonth() + 1).padStart(2, '0');\r",
                  "const day = String(now.getDate()).padStart(2, '0');\r",
                  "const dateStr = `${year}${month}${day}`;\r",
                  "\r",
                  "// 2. 겹치지 않도록 4자리 랜덤 숫자 생성\r",
                  "const randomNum = Math.floor(1000 + Math.random() * 9000);\r",
                  "\r",
                  "// 3. 특정 명칭과 조합 (예: skechers_qa_20260323_1234)\r",
                  "const uniqueName = `skechers_qa_${dateStr}_${randomNum}`;\r",
                  "const uniqueEmail = `${uniqueName}@example.com`;\r",
                  "\r",
                  "// 4. Postman 환경 변수(또는 임시 변수)에 저장\r",
                  "pm.variables.set(\"dynamicName\", uniqueName);\r",
                  "pm.variables.set(\"dynamicEmail\", uniqueEmail);\r",
                  "\r",
                  "console.log(\"생성된 이름:\", uniqueName);\r",
                  "console.log(\"생성된 이메일:\", uniqueEmail);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "ec44a27cf897f603e5d039624c58f6d44514f66caa7ffd78364d3b8027f81c1f",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "https://gorest.co.in/public/v2/users",
              "protocol": "https",
              "host": [
                "gorest",
                "co",
                "in"
              ],
              "path": [
                "public",
                "v2",
                "users"
              ]
            }
          },
